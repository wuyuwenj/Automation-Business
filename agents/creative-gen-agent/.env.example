# Nevermined (required)
NVM_API_KEY=sandbox:your-api-key
NVM_ENVIRONMENT=sandbox
NVM_PLAN_ID=your-plan-id
NVM_AGENT_ID=your-agent-id          # required for A2A mode

# OpenAI (required for local creative generation and Strands routing)
OPENAI_API_KEY=sk-your-key
MODEL_ID=gpt-4o-mini

# Gemini (for landing page generation)
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL_ID=gemini-2.5-pro
GEMINI_FALLBACK_MODEL_ID=gemini-2.5-flash

# Optional S3 upload for landing page previews
# LANDING_PAGE_S3_BUCKET=your-bucket-name
# LANDING_PAGE_S3_PREFIX=landing-pages
# LANDING_PAGE_PUBLIC_BASE_URL=https://cdn.example.com
# LANDING_PAGE_URL_EXPIRES_SECONDS=86400

# LLM - Bedrock (for AgentCore with agent_agentcore.py)
# AWS_REGION=us-west-2
# BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0

# Server
PORT=3000

# A2A Server (for agent-a2a mode)
A2A_PORT=9000

# Buyer registration URL (for auto-registration with buyer)
BUYER_URL=

# Observability (A2A mode only) - routes Strands routing model calls through Nevermined proxy
OBSERVABILITY_ENABLED=false

# AgentCore deployment (for agent-a2a-agentcore mode)
# PORT=8080
# AGENT_URL=https://your-agent.agentcore.aws
