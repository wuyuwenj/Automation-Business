# Seller's API key (builder/publisher)
SELLER_NVM_API_KEY=sandbox:...
# Buyer's API key (subscriber)
BUYER_NVM_API_KEY=sandbox:...

# Seller's plan and agent IDs
NVM_PLAN_ID=...
NVM_AGENT_ID=...

# Shared
NVM_ENVIRONMENT=sandbox
AWS_REGION=us-west-2

# Optional: override Bedrock model (default: us.amazon.nova-pro-v1:0)
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
